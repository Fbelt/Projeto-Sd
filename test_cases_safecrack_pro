// Testbench do SafeCrack Pro
// Testa os Casos Principais: Senha Correta, Senha Errada, Wrap-Around e Reset no Meio da Digitacao

`timescale 1ns/1ps

module safecrack_pro_tb;

    // Entradas e Saidas do DUT
    reg CLOCK_50;
    reg [3:0] KEY;
    wire [6:0] HEX0, HEX1, HEX2, HEX3, HEX4;
    wire [8:0] LEDG;
    wire [17:0] LEDR;

    // Instancia o Modulo que Queremos Testar
    safecrack_pro dut (
        .CLOCK_50(CLOCK_50),
        .KEY(KEY),
        .HEX0(HEX0),
        .HEX1(HEX1),
        .HEX2(HEX2),
        .HEX3(HEX3),
        .HEX4(HEX4),
        .LEDG(LEDG),
        .LEDR(LEDR)
    );

    // Gera Clock de 50MHz: Periodo = 20ns
    initial CLOCK_50 = 0;
    always #10 CLOCK_50 = ~CLOCK_50;

    // Botoes em Repouso = 1 (ativo baixo)
    initial KEY = 4'b1111;

    // Task: Pressiona um Botao por 22ms (passa os 20ms de debounce)
    task pressiona;
        input integer btn;
        begin
            KEY[btn] = 0;
            #22_000_000; // 22ms em nanosegundos
            KEY[btn] = 1;
            #5_000_000;  // 5ms de folga antes do proximo pulso
        end
    endtask

    // Task: Espera uma Condicao com Timeout para nao Travar
    task espera_com_timeout;
        input [63:0] ciclos_max;
        input [0:0] condicao;
    endtask

    // Bloco Principal de Testes
    integer timeout;

    initial begin
        #100; // espera o circuito estabilizar

        // TESTE 1: Reset Inicial
        $display("=== TESTE 1: reset inicial ===");
        pressiona(0);
        #100;
        $display("HEX3 = %b | esperado 1000000 (digito 0)", HEX3);
        $display("HEX4 = %b | esperado 1111001 (posicao 0)", HEX4);

        // TESTE 2: Senha Correta (1-2-3-4)
        $display("");
        $display("=== TESTE 2: senha correta 1-2-3-4 ===");

        // Digito0 = 1: Incrementa 1x e Confirma
        pressiona(2);
        $display("digito0 incrementado: HEX3 = %b | esperado 1111001 (1)", HEX3);
        pressiona(1); // Confirma e vai para Digito1

        // Digito1 = 2: Incrementa 2x e Confirma
        pressiona(2);
        pressiona(2);
        $display("digito1 incrementado: HEX2 = %b | esperado 0100100 (2)", HEX2);
        pressiona(1); // Confirma e vai para Digito2

        // Digito2 = 3: Incrementa 3x e Confirma
        pressiona(2);
        pressiona(2);
        pressiona(2);
        $display("digito2 incrementado: HEX1 = %b | esperado 0110000 (3)", HEX1);
        pressiona(1); // Confirma e vai para Digito3

        // Digito3 = 4: Incrementa 4x e Confirma
        pressiona(2);
        pressiona(2);
        pressiona(2);
        pressiona(2);
        $display("digito3 incrementado: HEX0 = %b | esperado 0011001 (4)", HEX0);
        pressiona(1); // Confirma e deve ir para ACERTO

        #100;
        if (LEDG == 9'b111111111)
            $display("PASSOU: leds verdes acenderam (ACERTO)");
        else
            $display("FALHOU: leds verdes nao acenderam | LEDG = %b", LEDG);

        // Espera Voltar ao inicio com Timeout de 6s (> 5s do timer)
        timeout = 0;
        while (LEDG != 0 && timeout < 300_000_000) begin
            @(posedge CLOCK_50);
            timeout = timeout + 1;
        end
        if (timeout >= 300_000_000)
            $display("FALHOU: timeout - nao saiu do estado ACERTO");
        else
            $display("PASSOU: voltou ao inicio apos ~5s (timeout = %0d ciclos)", timeout);

        // TESTE 3: senha errada (0-0-0-0)
        $display("");

        // Sem Incrementar, Confirma os Quatro Digitos como 0
        pressiona(1);
        pressiona(1);
        pressiona(1);
        pressiona(1);

        #100;
        if (LEDR == 18'b111111111111111111)
            $display("PASSOU: leds vermelhos acenderam (ERRO)");
        else
            $display("FALHOU: leds vermelhos nao acenderam | LEDR = %b", LEDR);

        // Espera Voltar com Timeout de 4s (> 3s do timer)
        timeout = 0;
        while (LEDR != 0 && timeout < 200_000_000) begin
            @(posedge CLOCK_50);
            timeout = timeout + 1;
        end
        if (timeout >= 200_000_000)
            $display("FALHOU: timeout - nao saiu do estado ERRO");
        else
            $display("PASSOU: voltou ao inicio apos ~3s (timeout = %0d ciclos)", timeout);

        // Teste 4: Wrap-Around - Decrementa de 0 e deve ir para 9
        $display("");
        $display("=== TESTE 4: wrap-around (decrementa de 0 vai para 9) ===");
        pressiona(3); // decrementa digito0
        #100;
        if (HEX3 == 7'b0010000)
            $display("PASSOU: HEX3 = %b (9)", HEX3);
        else
            $display("FALHOU: HEX3 = %b | esperado 0010000 (9)", HEX3);

        // Testa Tambem Wrap para Cima: Incrementa de 9 e deve ir para 0
        // Digito0 em 9 agora
        pressiona(2); // Deve ir para 0
        #100;
        if (HEX3 == 7'b1000000)
            $display("PASSOU: wrap para cima ok, HEX3 = %b (0)", HEX3);
        else
            $display("FALHOU: HEX3 = %b | esperado 1000000 (0)", HEX3);

        // TESTE 5: Reset no Meio da Digitacao
        $display("");
        $display("=== TESTE 5: reset no meio da digitacao ===");

        // Digita Alguns Valores
        pressiona(2);
        pressiona(2);
        pressiona(2); // Digito0 = 3
        pressiona(1); // Confirma e vai para DIGITO1
        pressiona(2);
        pressiona(2); // Digito1 = 2

        // Reseta no meio
        pressiona(0);
        #100;

        // Depois do Reset Tudo Volta a Zero e Volta para DIGITO0
        if (HEX3 == 7'b1000000 && HEX4 == 7'b1111001)
            $display("PASSOU: reset ok - HEX3=%b(0) HEX4=%b(pos 0)", HEX3, HEX4);
        else
            $display("FALHOU: HEX3=%b HEX4=%b | esperado HEX3=1000000 HEX4=1111001", HEX3, HEX4);

        // Fim
        $display("");
        $display("=== simulacao concluida ===");
        $finish; // encerra a simulacao (mais correto que $stop)
    end

endmodule
